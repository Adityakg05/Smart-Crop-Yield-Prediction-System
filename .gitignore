# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.so
*.egg
*.egg-info/
.eggs/
dist/
build/
MANIFEST

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Environment / secrets ──────────────────────────────────────────────────────
.env
.env.local
.env.production
.env.*.local
*.secret

# ── Database ───────────────────────────────────────────────────────────────────
# The SQLite file is auto-created at startup — no need to version it
backend/database/*.db
*.sqlite
*.sqlite3

# ── Dataset (large binary, share via Google Drive / DVC instead) ───────────────
backend/data/*.csv
backend/data/*.xlsx
backend/data/*.xls
backend/data/*.parquet

# ── Saved model artifacts ─────────────────────────────────────────────────────
models/*.pkl
models/*.joblib
models/*.h5
models/*.pth
models/*.onnx

# ── Logs ───────────────────────────────────────────────────────────────────────
*.log
logs/
prediction_log.jsonl

# ── IDE / editor ───────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ─────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Test / coverage ────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── Misc ────────────────────────────────────────────────────────────────────────
.cache/
output/
results/
